# ProxyMind canonical runtime configuration.
# Loaded first by Docker Compose env_file and by backend/app/core/config.py.
# backend/.env is loaded after this file and may override backend-local values.

# Core infrastructure (local Docker defaults)
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=proxymind
POSTGRES_PASSWORD=proxymind
POSTGRES_DB=proxymind

REDIS_HOST=redis
REDIS_PORT=6379

QDRANT_HOST=qdrant
QDRANT_PORT=6333

SEAWEEDFS_HOST=seaweedfs
SEAWEEDFS_FILER_PORT=8888
SEAWEEDFS_SOURCES_PATH=/sources

# Build/audit metadata. Auto-populated for image builds when available.
# Local example:
#   GIT_COMMIT_SHA=$(git rev-parse HEAD) docker compose build
GIT_COMMIT_SHA=

# Gemini / Google GenAI
# Gemini API keys:
#   https://aistudio.google.com/app/api-keys
# Vertex AI auth/project setup:
#   https://console.cloud.google.com/vertex-ai/studio/settings/api-keys
#   https://console.cloud.google.com/projectcreate
#   https://cloud.google.com/vertex-ai/generative-ai/docs/start/gcp-auth
#   https://cloud.google.com/docs/authentication/provide-credentials-adc
GEMINI_API_KEY=
GOOGLE_GENAI_USE_VERTEXAI=false
# Google Cloud project ID, not API key. Example: proxymind-dev-123456
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=global

# Embeddings and batch processing
EMBEDDING_MODEL=gemini-embedding-2-preview
EMBEDDING_DIMENSIONS=3072
EMBEDDING_TASK_TYPE=RETRIEVAL_DOCUMENT
EMBEDDING_BATCH_SIZE=100
BATCH_EMBED_CHUNK_THRESHOLD=50
BATCH_POLL_INTERVAL_SECONDS=30
BATCH_MAX_ITEMS_PER_REQUEST=1000
ENRICHMENT_ENABLED=false
ENRICHMENT_MODEL=gemini-2.5-flash
ENRICHMENT_MAX_CONCURRENCY=10
ENRICHMENT_TEMPERATURE=0.1
ENRICHMENT_MAX_OUTPUT_TOKENS=512
ENRICHMENT_MIN_CHUNK_TOKENS=10
GEMINI_CONTENT_MODEL=gemini-3-flash-preview
GEMINI_FILE_UPLOAD_THRESHOLD_BYTES=10485760

# Document AI / Path C fallback. Leave blank to keep Path C disabled.
# Create/select a Google Cloud project:
#   https://console.cloud.google.com/projectcreate
# Create a Document AI processor (Processor Gallery):
#   https://console.cloud.google.com/ai/document-ai/processor-library
# View existing Document AI processors:
#   https://console.cloud.google.com/ai/document-ai/processors
# Setup guide:
#   https://cloud.google.com/document-ai/docs/create-processor
DOCUMENT_AI_PROJECT_ID=
DOCUMENT_AI_LOCATION=us
DOCUMENT_AI_PROCESSOR_ID=
CHUNK_MAX_TOKENS=1024
PARENT_CHILD_MIN_DOCUMENT_TOKENS=1500
PARENT_CHILD_MIN_FLAT_CHUNKS=6
PARENT_CHILD_PARENT_TARGET_TOKENS=1200
PARENT_CHILD_PARENT_MAX_TOKENS=1800
PATH_C_MIN_CHARS_PER_PAGE=50
PATH_A_TEXT_THRESHOLD_PDF=2000
PATH_A_TEXT_THRESHOLD_MEDIA=500
PATH_A_MAX_PDF_PAGES=6
PATH_A_MAX_AUDIO_DURATION_SEC=80
PATH_A_MAX_VIDEO_DURATION_SEC=120

# Retrieval
QDRANT_COLLECTION=proxymind_chunks
BM25_LANGUAGE=english
SPARSE_BACKEND=bm25
# Required only when SPARSE_BACKEND=bge_m3.
BGE_M3_PROVIDER_URL=
BGE_M3_MODEL_NAME=bge-m3
BGE_M3_TIMEOUT_SECONDS=10.0

# Chat LLM
# LLM_API_KEY is provider-agnostic. Put the key for the provider selected below.
# OpenAI keys:
#   https://platform.openai.com/api-keys
#   https://developers.openai.com/api/reference/overview
# Z.AI keys and OpenAI-compatible base URL:
#   https://z.ai/manage-apikey/apikey-list
#   https://z.ai/model-api
#   https://docs.z.ai/api-reference/introduction
# GLM Coding Plan:
#   Use LiteLLM's OpenAI provider prefix with the dedicated coding endpoint.
LLM_MODEL=openai/glm-5.1
LLM_API_KEY=
LLM_API_BASE=https://api.z.ai/api/coding/paas/v4
LLM_TEMPERATURE=0.7
RETRIEVAL_TOP_N=5
MIN_RETRIEVED_CHUNKS=1
MAX_CITATIONS_PER_RESPONSE=5
RETRIEVAL_CONTEXT_BUDGET=4096
MAX_PROMOTIONS_PER_RESPONSE=1
MIN_DENSE_SIMILARITY=

# Streaming and rewrite
SSE_HEARTBEAT_INTERVAL_SECONDS=15
SSE_INTER_TOKEN_TIMEOUT_SECONDS=30
REWRITE_ENABLED=true
REWRITE_LLM_MODEL=
REWRITE_LLM_API_KEY=
REWRITE_LLM_API_BASE=
REWRITE_TEMPERATURE=0.1
REWRITE_TIMEOUT_MS=3000
REWRITE_TOKEN_BUDGET=2048
REWRITE_HISTORY_MESSAGES=10

# Conversation memory
CONVERSATION_MEMORY_BUDGET=4096
CONVERSATION_SUMMARY_RATIO=0.3
CONVERSATION_SUMMARY_MODEL=
CONVERSATION_SUMMARY_TEMPERATURE=0.1
CONVERSATION_SUMMARY_TIMEOUT_MS=10000

# Optional path overrides. Leave commented to use repo defaults.
# PERSONA_DIR=
# CONFIG_DIR=
# PROMOTIONS_FILE_PATH=

# Backend defaults
LOG_LEVEL=info
UPLOAD_MAX_FILE_SIZE_MB=100
API_HOST=0.0.0.0
API_PORT=8000
CHAT_RATE_LIMIT=60
CHAT_RATE_WINDOW_SECONDS=60
AUTH_SENSITIVE_RATE_LIMIT=10
AUTH_SENSITIVE_RATE_WINDOW_SECONDS=60
TRUSTED_PROXY_DEPTH=1

# End-user authentication
# Generate a strong value, for example:
#   openssl rand -hex 32
JWT_SECRET_KEY=replace-with-64-hex-characters-minimum
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
AUTH_COOKIE_SECURE=false
EMAIL_BACKEND=console
# Required only when EMAIL_BACKEND=resend
RESEND_API_KEY=
# Optional dev/test-only mail outbox directory for console email backend.
EMAIL_OUTBOX_DIR=
EMAIL_FROM=ProxyMind <noreply@example.com>
FRONTEND_URL=http://localhost:5173
# Playwright auth E2E only. This is a shared test-only password for isolated suites.
# Do not copy it into production envs.
E2E_TEST_PASSWORD=Cycle4Pass123!

# Local non-compose defaults.
# Docker Compose overrides these for api/worker containers.
OTEL_ENABLED=false
OTEL_SERVICE_NAME=proxymind-api
OTEL_ENVIRONMENT=development
OTEL_EXPORTER_OTLP_ENDPOINT=http://tempo:4317
