LOG_LEVEL=debug
LLM_MODEL=openai/gpt-4o
LLM_API_KEY=
LLM_API_BASE=
# LLM_TEMPERATURE=0.7
# RETRIEVAL_TOP_N=5
# MIN_RETRIEVED_CHUNKS=1
# MIN_DENSE_SIMILARITY=

# --- Security (S7-01) ---
# API key for admin endpoints. Admin API blocked (503) when not set.
# ADMIN_API_KEY=your-secret-key-here

# Rate limiting for Chat API
# CHAT_RATE_LIMIT=60
# CHAT_RATE_WINDOW_SECONDS=60

# X-Forwarded-For depth (1 = one trusted proxy like Caddy)
# TRUSTED_PROXY_DEPTH=1
# Required: the outermost trusted proxy must overwrite X-Forwarded-For,
# for example in Caddy: header_up X-Forwarded-For {remote_host}
