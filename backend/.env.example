# Backend-local overrides. Loaded after ../.env by Docker Compose and pydantic-settings.
# Provider/API key setup for Gemini, OpenAI, and Z.AI lives in ../.env.example.
# Direct links:
#   Gemini: https://ai.google.dev/gemini-api/docs/api-key
#   OpenAI: https://platform.openai.com/api-keys
#   Z.AI: https://z.ai/manage-apikey/apikey-list

LOG_LEVEL=debug

# Admin API secret. Generate locally, for example:
#   openssl rand -hex 32
ADMIN_API_KEY=

# Optional direct env exports that are used outside Settings.
# Keep them commented here; exporting them as active assignments in this file
# breaks pydantic-settings validation because backend/.env is also parsed by Settings.
# Reuse ADMIN_API_KEY for protected eval runs:
# PROXYMIND_ADMIN_API_KEY=
# Inside backend-test / Docker Compose use: http://api:8000
# From the host use: http://localhost:8000
# PROXYMIND_EVAL_BASE_URL=http://api:8000
# Optional dedicated judge model for answer-quality evals.
# Falls back to LLM_MODEL from ../.env when blank.
# EVAL_JUDGE_MODEL=
# Entrypoint retry knobs used by backend/entrypoint.sh.
# ALEMBIC_MAX_ATTEMPTS=10
# ALEMBIC_RETRY_DELAY_SECONDS=2

# Optional local backend overrides if you need them:
# CHAT_RATE_LIMIT=60
# CHAT_RATE_WINDOW_SECONDS=60
# AUTH_SENSITIVE_RATE_LIMIT=10
# AUTH_SENSITIVE_RATE_WINDOW_SECONDS=60
# TRUSTED_PROXY_DEPTH=1
# JWT_SECRET_KEY=replace-with-64-hex-characters-minimum
# JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
# JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
# AUTH_COOKIE_SECURE=false
# EMAIL_BACKEND=console
# RESEND_API_KEY=
# EMAIL_OUTBOX_DIR=
# EMAIL_FROM=ProxyMind <noreply@example.com>
# FRONTEND_URL=http://localhost:5173
