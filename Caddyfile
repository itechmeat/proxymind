:80 {
    @api path /api/*
    reverse_proxy @api localhost:8000 {
        # S7-01: overwrite X-Forwarded-For so chat rate limiting keys on the
        # direct client IP observed by Caddy, not a spoofable incoming header.
        header_up X-Forwarded-For {remote_host}
    }

    root * frontend/dist
    try_files {path} /index.html
    file_server
}
