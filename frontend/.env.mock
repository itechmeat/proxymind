# Mock mode — all API calls are intercepted by MSW (no backend needed).
# Start with: bun run dev:mock
VITE_MOCK_MODE=true
# Empty — requests go to relative /api/* paths, intercepted by MSW.
VITE_API_URL=
VITE_DEFAULT_LANGUAGE=en
VITE_TWIN_NAME=ProxyMindBooks
VITE_TWIN_AVATAR_URL=/api/chat/twin/avatar
VITE_ADMIN_MODE=true
